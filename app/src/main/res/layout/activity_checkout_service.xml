<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_gray">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔧 Đặt Lịch Dịch Vụ"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/primary_blue"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📋 Thông tin liên hệ"
            android:textStyle="bold"
            android:textColor="@color/text_dark"/>

        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Họ và tên *"
            android:background="@drawable/search_background"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etPhone"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Số điện thoại *"
            android:inputType="phone"
            android:background="@drawable/search_background"
            android:paddingHorizontal="16dp"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etAddress"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:hint="Địa chỉ *"
            android:gravity="top"
            android:background="@drawable/search_background"
            android:padding="16dp"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📅 Chọn lịch hẹn"
            android:textStyle="bold"
            android:textColor="@color/text_dark"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btnPickDate"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="📅 Chọn ngày"
                android:background="@drawable/button_primary"
                android:textColor="@color/white"
                android:layout_marginEnd="6dp"/>

            <Button
                android:id="@+id/btnPickTime"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="⏰ Chọn giờ"
                android:background="@drawable/button_secondary"
                android:textColor="@color/white"
                android:layout_marginStart="6dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ngày:"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvServiceDate"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Chưa chọn"
                android:textColor="@color/primary_blue"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Giờ:"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvServiceTime"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Chưa chọn"
                android:textColor="@color/primary_blue"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💳 Phương thức thanh toán"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            android:layout_marginTop="20dp"/>

        <RadioGroup
            android:id="@+id/rgPayment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <RadioButton
                android:id="@+id/rbCash"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💵 Thanh toán khi hoàn thành (COD)"
                android:checked="true"
                android:padding="12dp"/>

            <RadioButton
                android:id="@+id/rbBank"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🏦 Chuyển khoản ngân hàng"
                android:padding="12dp"/>

            <RadioButton
                android:id="@+id/rbMomo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📱 Ví MoMo"
                android:padding="12dp"/>
        </RadioGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📝 Ghi chú thêm"
            android:textStyle="bold"
            android:textColor="@color/text_dark"
            android:layout_marginTop="20dp"/>

        <EditText
            android:id="@+id/etNotes"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:hint="Mô tả thêm yêu cầu..."
            android:gravity="top"
            android:background="@drawable/search_background"
            android:padding="16dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tổng cộng:"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"/>

            <TextView
                android:id="@+id/tvTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0đ"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/price_red"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnConfirm"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="✅ Xác nhận đặt lịch"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            android:background="@drawable/button_primary"
            android:textColor="@color/white"/>

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Hủy"
            android:textSize="16sp"
            android:layout_marginTop="12dp"
            android:background="@drawable/search_background"
            android:textColor="@color/text_medium"/>
    </LinearLayout>
</ScrollView>