<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header: Item Name + Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvItemName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Vệ sinh máy lạnh"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"/>

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chờ xác nhận"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/category_badge_service"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"/>
        </LinearLayout>

        <!-- Item Type Badge -->
        <TextView
            android:id="@+id/tvItemType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔧 Dịch vụ"
            android:textSize="12sp"
            android:textStyle="bold"
            android:background="@drawable/category_badge_product"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:layout_marginTop="8dp"/>

        <!-- Service Date -->
        <TextView
            android:id="@+id/tvServiceDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📅 Hẹn: 20/04/2026 14:00"
            android:textSize="13sp"
            android:textColor="@color/accent_orange"
            android:textStyle="bold"
            android:layout_marginTop="4dp"
            android:visibility="gone"/>

        <!-- Info Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/tvDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📅 18/04/2026 10:30"
                android:textSize="13sp"
                android:textColor="@color/text_medium"/>

            <TextView
                android:id="@+id/tvQuantity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Số lượng: 1"
                android:textSize="13sp"
                android:textColor="@color/text_medium"
                android:layout_marginTop="4dp"/>

            <TextView
                android:id="@+id/tvPayment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="💵 Thanh toán khi nhận hàng"
                android:textSize="13sp"
                android:textColor="@color/text_medium"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="12dp"/>

        <!-- Total Amount -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tổng cộng:"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_dark"/>

            <TextView
                android:id="@+id/tvTotal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="150.000đ"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/price_red"/>
        </LinearLayout>

        <!-- Action Buttons - SỬA HEIGHT TỪ 44dp LÊN 48dp -->
        <LinearLayout
            android:id="@+id/layoutActions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="❌ Hủy đơn"
                android:textSize="13sp"
                android:background="@drawable/search_background"
                android:textColor="@color/price_red"
                android:layout_marginEnd="6dp"
                android:minHeight="48dp"/>

            <Button
                android:id="@+id/btnDetail"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="📄 Chi tiết"
                android:textSize="13sp"
                android:background="@drawable/button_primary"
                android:textColor="@color/white"
                android:layout_marginStart="6dp"
                android:minHeight="48dp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>